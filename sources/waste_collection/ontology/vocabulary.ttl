@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix soilcom: <https://brit.bioresource-tools.net/ontology/soilcom#> .
@prefix britvoc: <https://brit.bioresource-tools.net/vocab/soilcom/> .

<https://brit.bioresource-tools.net/vocab/soilcom>
    a owl:Ontology ;
    dcterms:title "BRIT Soilcom controlled vocabulary"@en ;
    owl:versionInfo "0.4.0" ;
    dcterms:created "2026-03-05"^^xsd:date .

britvoc:scheme/waste-category a skos:ConceptScheme ;
    skos:prefLabel "Waste category"@en .

britvoc:concept/waste-category/biowaste a skos:Concept ;
    skos:inScheme britvoc:scheme/waste-category ;
    skos:prefLabel "Biowaste"@en .

britvoc:concept/waste-category/food-waste a skos:Concept ;
    skos:inScheme britvoc:scheme/waste-category ;
    skos:prefLabel "Food waste"@en .

britvoc:concept/waste-category/green-waste a skos:Concept ;
    skos:inScheme britvoc:scheme/waste-category ;
    skos:prefLabel "Green waste"@en .

britvoc:concept/waste-category/residual-waste a skos:Concept ;
    skos:inScheme britvoc:scheme/waste-category ;
    skos:prefLabel "Residual waste"@en ;
    skos:prefLabel "Restabfall"@de ;
    skos:altLabel "Restmüll"@de ;
    skos:altLabel "Hausmüll"@de ;
    skos:hiddenLabel "Restmuell"@de ;
    skos:hiddenLabel "Hausmuell"@de .

britvoc:scheme/collection-system a skos:ConceptScheme ;
    skos:prefLabel "Collection system"@en .

britvoc:concept/collection-system/bring-point a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "Bring point"@en .

britvoc:concept/collection-system/door-to-door a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "Door to door"@en .

britvoc:concept/collection-system/home-composting a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "Home-composting"@en .

britvoc:concept/collection-system/no-separate-collection a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "No separate collection"@en .

britvoc:concept/collection-system/on-demand-kerbside-collection a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "On demand kerbside collection"@en .

britvoc:concept/collection-system/recycling-centre a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-system ;
    skos:prefLabel "Recycling centre"@en .

britvoc:scheme/collection-frequency a skos:ConceptScheme ;
    skos:prefLabel "Collection frequency"@en ;
    rdfs:comment "Detailed frequency values are maintained in the live Django data export."@en .

britvoc:concept/collection-frequency/fixed a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-frequency ;
    skos:prefLabel "Fixed"@en .

britvoc:concept/collection-frequency/fixed-flexible a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-frequency ;
    skos:prefLabel "Fixed-Flexible"@en .

britvoc:concept/collection-frequency/fixed-seasonal a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-frequency ;
    skos:prefLabel "Fixed-Seasonal"@en .

britvoc:concept/collection-frequency/seasonal a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-frequency ;
    skos:prefLabel "Seasonal"@en .

britvoc:scheme/bin-configuration a skos:ConceptScheme ;
    skos:prefLabel "Bin configuration"@en .

britvoc:concept/bin-configuration/four-compartments-bin a skos:Concept ;
    skos:inScheme britvoc:scheme/bin-configuration ;
    skos:prefLabel "Four compartments bin"@en .

britvoc:concept/bin-configuration/optical-bag-sorting a skos:Concept ;
    skos:inScheme britvoc:scheme/bin-configuration ;
