britvoc:concept/bin-configuration/two-compartments-bin a skos:Concept ;
    skos:inScheme britvoc:scheme/bin-configuration ;
    skos:prefLabel "Two compartments bin"@en .

britvoc:scheme/fee-system a skos:ConceptScheme ;
    skos:prefLabel "Fee system"@en .

britvoc:concept/fee-system/flat-fee a skos:Concept ;
    skos:inScheme britvoc:scheme/fee-system ;
    skos:prefLabel "Flat fee"@en .

britvoc:concept/fee-system/flexible a skos:Concept ;
    skos:inScheme britvoc:scheme/fee-system ;
    skos:prefLabel "Flexible"@en .

britvoc:concept/fee-system/flexible-plus a skos:Concept ;
