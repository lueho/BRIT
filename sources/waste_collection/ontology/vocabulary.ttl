britvoc:scheme/material a skos:ConceptScheme ;
    skos:prefLabel "Material"@en ;
    rdfs:comment "Material terms used by allowed/forbidden constraints are exported from Django data."@en .

britvoc:scheme/unit a skos:ConceptScheme ;
    skos:prefLabel "Unit"@en .

britvoc:concept/unit/kg-per-cap-a a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "kg/(cap.*a)"@en .

britvoc:concept/unit/mg-per-a a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "Mg/a"@en .

britvoc:concept/unit/percent-households a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "% of households"@en .

britvoc:concept/unit/percent-population a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "% of population"@en .

britvoc:concept/unit/percent-residential-properties a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "% of residential properties"@en .

britvoc:concept/unit/percent-residual-waste-bins a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "% of residual waste bins"@en .

britvoc:concept/unit/percent-unknown-reference a skos:Concept ;
    skos:inScheme britvoc:scheme/unit ;
    skos:prefLabel "% (of unknown reference)"@en .

britvoc:scheme/material-role a skos:ConceptScheme ;
    skos:prefLabel "Material role"@en .

britvoc:concept/material-role/allowed a skos:Concept ;
    skos:inScheme britvoc:scheme/material-role ;
    skos:prefLabel "allowed"@en .

britvoc:concept/material-role/forbidden a skos:Concept ;
    skos:inScheme britvoc:scheme/material-role ;
    skos:prefLabel "forbidden"@en .

britvoc:scheme/connection-type a skos:ConceptScheme ;
    skos:prefLabel "Connection type"@en .

britvoc:concept/connection-type/mandatory a skos:Concept ;
    skos:inScheme britvoc:scheme/connection-type ;
    skos:prefLabel "mandatory"@en ;
    skos:notation "MANDATORY" .

britvoc:concept/connection-type/mandatory-with-home-composter-exception a skos:Concept ;
    skos:inScheme britvoc:scheme/connection-type ;
    skos:prefLabel "mandatory with exception for home composters"@en ;
    skos:notation "MANDATORY_WITH_HOME_COMPOSTER_EXCEPTION" .

britvoc:concept/connection-type/voluntary a skos:Concept ;
    skos:inScheme britvoc:scheme/connection-type ;
    skos:prefLabel "voluntary"@en ;
    skos:notation "VOLUNTARY" .

britvoc:concept/connection-type/not-specified a skos:Concept ;
    skos:inScheme britvoc:scheme/connection-type ;
    skos:prefLabel "not specified"@en ;
    skos:notation "not_specified" .

britvoc:scheme/required-bin-capacity-reference a skos:ConceptScheme ;
    skos:prefLabel "Required bin capacity reference"@en .

britvoc:concept/required-bin-capacity-reference/person a skos:Concept ;
    skos:inScheme britvoc:scheme/required-bin-capacity-reference ;
    skos:prefLabel "per person"@en ;
