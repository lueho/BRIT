britvoc:scheme/country-language a skos:ConceptScheme ;
    skos:prefLabel "Country language map"@en .

britvoc:concept/country-language/be a skos:Concept ;
    skos:inScheme britvoc:scheme/country-language ;
    skos:prefLabel "Belgium"@en ;
    skos:notation "BE" ;
    soilcom:languageCode "nl", "fr", "de" .

britvoc:concept/country-language/de a skos:Concept ;
    skos:inScheme britvoc:scheme/country-language ;
    skos:prefLabel "Germany"@en ;
    skos:notation "DE" ;
    soilcom:languageCode "de" .

britvoc:concept/country-language/dk a skos:Concept ;
    skos:inScheme britvoc:scheme/country-language ;
    skos:prefLabel "Denmark"@en ;
    skos:notation "DK" ;
    soilcom:languageCode "da" .

britvoc:concept/country-language/nl a skos:Concept ;
    skos:inScheme britvoc:scheme/country-language ;
    skos:prefLabel "Netherlands"@en ;
    skos:notation "NL" ;
    soilcom:languageCode "nl" .

britvoc:concept/country-language/se a skos:Concept ;
    skos:inScheme britvoc:scheme/country-language ;
    skos:prefLabel "Sweden"@en ;
    skos:notation "SE" ;
    soilcom:languageCode "sv" .

britvoc:concept/country-language/uk a skos:Concept ;
