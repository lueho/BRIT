britvoc:concept/required-bin-capacity-reference/household a skos:Concept ;
    skos:inScheme britvoc:scheme/required-bin-capacity-reference ;
    skos:prefLabel "per household"@en ;
    skos:notation "household" .

britvoc:concept/required-bin-capacity-reference/property a skos:Concept ;
    skos:inScheme britvoc:scheme/required-bin-capacity-reference ;
