britvoc:scheme/collection-property a skos:ConceptScheme ;
    skos:prefLabel "Collection property"@en .

britvoc:concept/collection-property/connection-rate a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-property ;
    skos:prefLabel "Connection rate"@en .

britvoc:concept/collection-property/specific-waste-collected a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-property ;
    skos:prefLabel "specific waste collected"@en .

britvoc:concept/collection-property/specific-waste-treated a skos:Concept ;
    skos:inScheme britvoc:scheme/collection-property ;
